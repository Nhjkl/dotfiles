FROM archlinux:latest

# 使用中国镜像加速
RUN echo 'Server = https://mirrors.tuna.tsinghua.edu.cn/archlinux/$repo/os/$arch' > /etc/pacman.d/mirrorlist && \
    echo 'Server = https://mirrors.aliyun.com/archlinux/$repo/os/$arch' >> /etc/pacman.d/mirrorlist

# 基础系统设置 + 预装第三方工具（避免 Docker 内 DNS 问题）
RUN pacman -Syu --noconfirm && \
    pacman -S --noconfirm --needed base-devel git curl wget sudo fzf \
    sheldon starship mise

# 创建测试用户（stow 不能以 root 运行到 home 目录）
RUN useradd -m -s /bin/bash testuser && \
    echo "testuser ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

USER testuser
WORKDIR /home/testuser

# 复制 dotfiles
COPY --chown=testuser:testuser . /home/testuser/dotfiles

# 非交互测试：用环境变量传递选择
ENV SELECTED="1-6"
ENV TERM=xterm-256color

# 运行安装脚本（模拟交互输入）
RUN cd /home/testuser/dotfiles && \
    echo "1-6" | bash install.sh || true

# 验证
CMD ["bash", "-c", "\
    echo '=== 验证安装 ===' && \
    echo '' && \
    echo '--- 符号链接 ---' && \
    ls -la ~/.zshenv 2>/dev/null || echo 'MISSING: ~/.zshenv' && \
    ls -la ~/.config/zsh/.zshrc 2>/dev/null || echo 'MISSING: ~/.config/zsh/.zshrc' && \
    ls -la ~/.config/git/config 2>/dev/null || echo 'MISSING: ~/.config/git/config' && \
    ls -la ~/.config/tmux/tmux.conf 2>/dev/null || echo 'MISSING: ~/.config/tmux/tmux.conf' && \
    ls -la ~/.config/nvim/init.lua 2>/dev/null || echo 'MISSING: ~/.config/nvim/init.lua' && \
    ls -la ~/.config/starship.toml 2>/dev/null || echo 'MISSING: ~/.config/starship.toml' && \
    echo '' && \
    echo '--- 命令检查 ---' && \
    which zsh && zsh --version && \
    which git && git --version && \
    which tmux && tmux -V && \
    which fzf && \
    which starship && \
    which sheldon && \
    which mise && \
    echo '' && \
    echo '--- Shell 配置加载测试 ---' && \
    zsh -c 'source ~/.config/zsh/.zshrc; echo OK: zshrc loaded' 2>&1 || echo 'WARN: zshrc load had issues' && \
    echo '' && \
    echo '=== 测试完成 ===' \
"]
