#!/bin/sh

CACHE_DIR="$HOME/.cache/imgview"
URL="$1"

[ -z "$URL" ] && { echo "Usage: imgview <image_url>"; exit 1; }

mkdir -p "$CACHE_DIR"

CACHE_FILE="$CACHE_DIR/$(echo -n "$URL" | md5sum | cut -d' ' -f1)"

if [ ! -f "$CACHE_FILE" ]; then
    wget -q -O "$CACHE_FILE" "$URL" || { echo "Download failed"; exit 1; }
fi

viu "$CACHE_FILE"
